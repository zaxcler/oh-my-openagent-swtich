{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "oh-my-openagent-switch",
  "version": "0.1.0",
  "identifier": "com.zaxcler.oh-my-openagent-switch",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "oh-my-openagent-switch",
        "width": 1024,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "msi", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
